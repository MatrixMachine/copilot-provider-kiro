{
  "name": "copilot-provider-kiro",
  "displayName": "Kiro for Copilot Chat",
  "description": "Pick Kiro (AWS CodeWhisperer/Q) models from the Copilot Chat model picker. Claude, DeepSeek, Qwen, and more — zero cost with your Kiro account.",
  "version": "0.1.0",
  "publisher": "kiro-community",
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=22"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "copilot",
    "kiro",
    "aws",
    "codewhisperer",
    "language model",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "icon": "icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "kiro",
        "displayName": "Kiro"
      }
    ],
    "commands": [
      {
        "command": "copilot-provider-kiro.login",
        "title": "Kiro: Login"
      },
      {
        "command": "copilot-provider-kiro.logout",
        "title": "Kiro: Logout"
      },
      {
        "command": "copilot-provider-kiro.status",
        "title": "Kiro: Show Status"
      },
      {
        "command": "copilot-provider-kiro.usage",
        "title": "Kiro: Show Usage"
      }
    ],
    "configuration": {
      "title": "Kiro for Copilot Chat",
      "properties": {
        "copilot-provider-kiro.region": {
          "type": "string",
          "default": "us-east-1",
          "description": "AWS region for the Kiro API endpoint"
        },
        "copilot-provider-kiro.modelIdOverrides": {
          "type": "object",
          "default": {
            "claude-opus-4-8": "claude-opus-4.8",
            "claude-opus-4-7": "claude-opus-4.7",
            "claude-opus-4-6": "claude-opus-4.6",
            "claude-sonnet-4-6": "claude-sonnet-4.6",
            "claude-sonnet-4-5": "claude-sonnet-4.5",
            "claude-sonnet-4": "claude-sonnet-4",
            "claude-haiku-4-5": "claude-haiku-4.5",
            "deepseek-3-2": "deepseek-3.2",
            "minimax-m2-5": "minimax-m2.5",
            "minimax-m2-1": "minimax-m2.1",
            "glm-5": "glm-5",
            "qwen3-coder-next": "qwen3-coder-next",
            "kiro-auto": "auto"
          },
          "description": "Override API model IDs sent to Kiro for each VS Code model ID (useful for custom gateways/proxies).",
          "additionalProperties": false,
          "properties": {
            "claude-opus-4-8": {
              "type": "string",
              "description": "API model ID override for Claude Opus 4.8"
            },
            "claude-opus-4-7": {
              "type": "string",
              "description": "API model ID override for Claude Opus 4.7"
            },
            "claude-opus-4-6": {
              "type": "string",
              "description": "API model ID override for Claude Opus 4.6"
            },
            "claude-sonnet-4-6": {
              "type": "string",
              "description": "API model ID override for Claude Sonnet 4.6"
            },
            "claude-sonnet-4-5": {
              "type": "string",
              "description": "API model ID override for Claude Sonnet 4.5"
            },
            "claude-sonnet-4": {
              "type": "string",
              "description": "API model ID override for Claude Sonnet 4"
            },
            "claude-haiku-4-5": {
              "type": "string",
              "description": "API model ID override for Claude Haiku 4.5"
            },
            "deepseek-3-2": {
              "type": "string",
              "description": "API model ID override for DeepSeek 3.2"
            },
            "minimax-m2-5": {
              "type": "string",
              "description": "API model ID override for MiniMax M2.5"
            },
            "minimax-m2-1": {
              "type": "string",
              "description": "API model ID override for MiniMax M2.1"
            },
            "glm-5": {
              "type": "string",
              "description": "API model ID override for GLM 5"
            },
            "qwen3-coder-next": {
              "type": "string",
              "description": "API model ID override for Qwen3 Coder Next"
            },
            "kiro-auto": {
              "type": "string",
              "description": "API model ID override for Kiro Auto"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=dist/extension.js --external:vscode",
    "watch": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=dist/extension.js --external:vscode --watch",
    "check": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@smithy/core": "^3.24.5"
  }
}
